{
  "manifest_version": 3,
  "name": "BotWatch — Fake Account Detector",
  "version": "1.0",
  "description": "Automatically detects fake Twitter accounts using machine learning.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "http://127.0.0.1:5000/*",
    "https://botwatch-6qpn.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon-default.png",
      "48":  "icon-default.png",
      "128": "icon-default.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"]
    }
  ]
}